---
import AppCard from '../components/AppCard.astro';

const apps = [
  {
    name: 'Libre Fasting',
    description: 'Your personal fasting tracker for a healthier lifestyle',
    icon: '/fasting-icon.png',
    color: '#ba6bffff',
    appStoreUrl: 'https://apps.apple.com/us/app/libre-fasting/id6754898343',
    comingSoon: false,
    features: [
      { short: 'Smart timer tracking', detail: 'Track Your Fasting Journey with Precision - Smart timer with milestone notifications and progress tracking that automatically extends beyond your target time to measure your achievement' },
      { short: 'Fasting science education', detail: 'Understand the Science of Fasting - Learn what happens in your body at every stage with an interactive timeline and access to 25+ curated fasting resources' },
      { short: 'Complete fasting history', detail: 'Complete Fasting History - Review all your past fasts, edit details, and export your data whenever you need it' },
			{ short: 'Weight & body fat % history', detail: 'Monitor Your Health Transformation - Log weight and body fat measurements with each fast to track your progress over time' },      
    ],
  },
  {
    name: 'Libre Pregnancy',
    description: 'A privacy-focused, offline-only pregnancy tracker for expecting parents.',
    icon: '/libre-pregnancy-icon.webp',
    color: '#4ECDC4',
    appStoreUrl: 'https://apps.apple.com/us/app/libre-pregnancy/id6754899999',
    comingSoon: false,
    features: [
      { short: 'Weekly updates and baby sizes', detail: 'Follow pregnancy week by week with development updates, baby size comparisons, practical to-dos, and educational content.' },
      { short: 'Kick counter and contraction timer', detail: 'Track baby movements and contractions alongside symptoms, vitals, appointments, provider questions, medications, and checklists.' },
      { short: 'Multitude of trackers', detail: 'Stay organized across singleton, twin, and multiple pregnancies with offline tools designed around privacy and simple record keeping.' },
      { short: 'Learning materials and citations', detail: 'Use cited learning materials without signups, accounts, cloud dependency, or data transfer outside your device.' },
    ],
  },
  {
    name: 'Libre Maze',
    description: 'Challenge your mind with endless maze puzzles',
    icon: '/libre-maze-icon.png',
    color: '#FFD93D',
    appStoreUrl: 'https://apps.apple.com/us/app/libre-maze/id6762308058',
    comingSoon: false,
    features: [
      { short: 'Unlimited random mazes', detail: 'Stay challenged with freshly generated mazes every run, built for replayability instead of memorizing the same layouts.' },
      { short: 'Various maze styles', detail: 'Switch between maze generation algorithms including Backtracking, Prim\'s, and Kruskal\'s for distinct pathing and puzzle flow.' },
      { short: 'Multiple difficulty levels', detail: 'Choose from four difficulty levels, fog-of-war pressure on harder runs, and adjustable maze sizes for quick sessions or larger layouts.' },
      { short: 'Stats, badges, and themes', detail: 'Track score and route efficiency, unlock badges over time, customize your runner emoji, and play offline with light or dark themes.' },
    ],
  },
  {
    name: 'Libre Fitness',
    description: 'Your personal fitness trainer in your pocket',
    icon: '💪',
    color: '#A8E6CF',
    features: ['Custom workout plans', 'Exercise library', 'Progress tracking', 'Fitness goals'],
  },
  {
    name: 'Libre Carnivore',
    description: 'Track your carnivore diet and optimize your nutrition',
    icon: '🥩',
    color: '#FF8B94',
    features: ['Meat macro tracking', 'Meal logging', 'Diet insights', 'Recipe ideas'],
  },
  {
    name: 'Libre Humidor',
    description: 'Manage your cigar collection like a pro',
    icon: '💨',
    color: '#95E1D3',
    features: ['Collection inventory', 'Humidity tracking', 'Tasting notes', 'Aging tracker'],
  },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Libre By Design - Mobile Apps</title>
		<meta name="description" content="Discover our collection of beautifully designed free mobile applications" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700;900&family=Inter:wght@400;600&display=swap" rel="stylesheet" />
		<meta name="google-site-verification" content="C98ZAzbFrMcVHUTiZQUlBvUK0u52R8quf9ambBCkSbQ" />
	</head>
	<body>
		<main>
			<header class="hero">
				<h1 class="hero-title">
					<span class="gradient-text">Libre By Design</span>
				</h1>
				<p class="hero-subtitle">Crafting beautiful free & simple mobile experiences</p>
			</header>

			<section class="apps-grid">
				{apps.map((app) => (
					<AppCard app={app} />
				))}
			</section>

		<section class="about-section">
			<h2 class="about-title">💡 About</h2>

			<p class="about-text">
				Built for humans, not profits.<br/>
				These apps are 100% open source — created by a Renaissance app artisan indie hacker, for the community.
			</p>

			<div class="feature-item">
				<span class="feature-icon">🆓</span>
				<p class="feature-text">
					<strong>Always free.</strong> No requests for emails. No subscriptions nudges. No paywalls. No feature creep. Ever.
				</p>
			</div>

			<div class="feature-item">
				<span class="feature-icon">🚫</span>
				<p class="feature-text">
					<strong>No ads. Ever.</strong> No tracking, no distractions, no irritation.
				</p>
			</div>

			<div class="feature-item">
				<span class="feature-icon">🔒</span>
				<p class="feature-text">
					<strong>Privacy first.</strong> Your data stays on your device. Nothing is uploaded or stored on any server.
				</p>
			</div>

			<div class="feature-item">
				<span class="feature-icon">📁</span>
				<p class="feature-text">
					<strong>Full control.</strong> You can export your data anytime as a simple CSV file — your fasts, your insights, your choice.
				</p>
			</div>

			<div class="feature-item">
				<span class="feature-icon">🧠</span>
				<p class="feature-text">
					<strong>Transparent code.</strong> Anyone can inspect, contribute, or improve the app — because open source means open trust.
				</p>
			</div>

			<div class="feature-item">
				<span class="feature-icon">🌿</span>
				<p class="feature-text">
					<strong>Pure simplicity.</strong> Every feature exists for a reason — no clutter, no confusion, just tools that stay out of your way.
				</p>
			</div>

			<p class="about-footer">
				These apps exist to help you — not to sell your data, your attention, or your peace of mind. Just simple apps that respect you.
			</p>

		</section>

			<footer>
				<p>&copy; 2025 Libre By Design LLC. All rights reserved.</p>
			</footer>
		</main>

		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			:root {
				--bg-dark: #0a0a0a;
				--bg-card: #1a1a1a;
				--text-primary: #ffffff;
				--text-secondary: #a0a0a0;
			}

			body {
				font-family: 'Inter', sans-serif;
				background: var(--bg-dark);
				color: var(--text-primary);
				line-height: 1.6;
				min-height: 100vh;
			}

			main {
				max-width: 1400px;
				margin: 0 auto;
				padding: 2rem;
			}

			.hero {
				text-align: center;
				padding: 4rem 0 6rem;
			}

			.hero-title {
				font-family: 'Poppins', sans-serif;
				font-weight: 900;
				font-size: clamp(3rem, 8vw, 6rem);
				margin-bottom: 1rem;
				letter-spacing: -0.02em;
			}

			.gradient-text {
				background: linear-gradient(135deg, #FF6B6B, #4ECDC4, #FFD93D, #A8E6CF);
				background-size: 300% 300%;
				-webkit-background-clip: text;
				background-clip: text;
				-webkit-text-fill-color: transparent;
				animation: gradient 8s ease infinite;
			}

			@keyframes gradient {
				0% { background-position: 0% 50%; }
				50% { background-position: 100% 50%; }
				100% { background-position: 0% 50%; }
			}

			.hero-subtitle {
				font-size: clamp(1.2rem, 3vw, 1.8rem);
				color: var(--text-secondary);
				font-weight: 600;
			}

			.apps-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2rem;
				margin-bottom: 4rem;
				grid-auto-rows: 1fr;
			}

			:global(.app-card-container) {
				height: 100%;
			}

			:global(.app-card) {
				background: var(--bg-card);
				border: 3px solid;
				border-radius: 20px;
				padding: 2rem;
				transition: all 0.3s ease;
				position: relative;
				overflow: hidden;
				min-height: 31.5rem;
				display: flex;
				flex-direction: column;
			}

			:global(.app-card-container:not([data-has-details="true"]):hover .app-card) {
				transform: translateY(-8px);
				box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
			}

			:global(.app-icon) {
				width: 80px;
				height: 80px;
				border-radius: 20px;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2.5rem;
				margin-bottom: 1.5rem;
				box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
				overflow: hidden;
				object-fit: cover;
			}

			:global(.app-icon[data-icon-type="image"]) {
				background: rgba(255, 255, 255, 0.08);
				border: 1px solid rgba(255, 255, 255, 0.18);
			}

			:global(.app-icon-image) {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: contain;
			}

		:global(.app-name) {
				font-family: 'Poppins', sans-serif;
				font-weight: 700;
				font-size: 1.8rem;
				margin-bottom: 0.5rem;
			}

			:global(.app-description) {
				color: var(--text-secondary);
				margin-bottom: 1.5rem;
				font-size: 1rem;
			}

			:global(.app-features) {
				list-style: none;
				margin-bottom: 1.75rem;
			}

			:global(.app-features li) {
				padding: 0;
				color: var(--text-secondary);
				position: relative;
				padding-left: 1.5rem;
				line-height: 1.45;
			}

			:global(.app-features li::before) {
				content: '→';
				position: absolute;
				left: 0;
				font-weight: bold;
			}

		:global(.coming-soon-ribbon) {
			position: absolute;
			top: 2.2rem;
			right: -5.8rem;
			background: rgba(255, 193, 7, 0.2);
			border: 2px solid #FFC107;
			color: #FFC107;
			padding: 0.5rem 4.5rem;
			border-radius: 4px;
			font-size: 0.7rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.5px;
			z-index: 10;
			transform: rotate(45deg);
			transform-origin: center;
			width: 7rem;
		}

			:global(.download-buttons) {
				--store-btn-gap: clamp(0.45rem, 1vw, 0.75rem);
				--store-btn-pad-y: clamp(0.6rem, 0.9vw, 0.8rem);
				--store-btn-pad-x: clamp(0.5rem, 1vw, 0.85rem);
				display: flex;
				gap: var(--store-btn-gap);
				flex-wrap: nowrap;
				justify-content: center;
				margin-top: auto;
			}

			:global(.store-btn) {
				flex: 1 1 0;
				min-width: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: var(--store-btn-gap);
			padding: var(--store-btn-pad-y) var(--store-btn-pad-x);
			border: 2px solid #404040;
			border-radius: 12px;
			background: rgba(64, 64, 64, 0.2);
			color: #666;
			font-weight: 600;
			font-size: clamp(0.75rem, 0.95vw, 0.9rem);
			cursor: not-allowed;
			transition: all 0.3s ease;
			font-family: 'Inter', sans-serif;
		}

		:global(.store-btn.disabled) {
			opacity: 0.5;
		}

		:global(a.store-btn) {
			text-decoration: none;
		}

		:global(.store-btn-enabled) {
			cursor: pointer;
			color: #f5f0ff;
			border-color: rgba(186, 107, 255, 0.7);
			background: rgba(186, 107, 255, 0.18);
			box-shadow: 0 0 0 1px rgba(186, 107, 255, 0.25) inset;
		}

		:global(.store-icon) {
			width: clamp(18px, 1.6vw, 20px);
			height: clamp(18px, 1.6vw, 20px);
		}

	.about-section {
		max-width: 800px;
		margin: 4rem auto;
		padding: 2.5rem;
		background: rgba(128, 128, 128, 0.05);
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.about-title {
		font-family: 'Poppins', sans-serif;
		font-weight: 700;
		font-size: 2rem;
		margin-bottom: 1.5rem;
		color: var(--text-primary);
	}

	.about-text {
		font-family: 'Inter', sans-serif;
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--text-secondary);
		margin-bottom: 2rem;
	}

	.feature-item {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.feature-icon {
		font-size: 1.5rem;
		flex-shrink: 0;
		margin-top: 0.2rem;
	}

	.feature-text {
		flex: 1;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		line-height: 1.6;
		color: var(--text-secondary);
		margin: 0;
	}

	.feature-text strong {
		font-weight: 600;
		color: var(--text-primary);
	}

	.about-footer {
		font-family: 'Inter', sans-serif;
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--text-secondary);
		margin-top: 2rem;
		margin-bottom: 1.5rem;
		font-style: italic;
	}

	.email-link {
		display: inline-block;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 1.1rem;
		color: #4ECDC4;
		text-decoration: underline;
		transition: opacity 0.3s ease;
	}

	.email-link:hover {
		opacity: 0.8;
	}

			footer {
				text-align: center;
				padding: 3rem 0;
				color: var(--text-secondary);
				border-top: 1px solid rgba(255, 255, 255, 0.1);
			}

			@media (max-width: 768px) {
				.apps-grid {
					grid-template-columns: 1fr;
				}

				main {
					padding: 1rem;
				}

				.hero {
					padding: 2rem 0 3rem;
				}
			}

			@media (max-width: 380px) {
				:global(.download-buttons) {
					flex-direction: column;
				}

				:global(.store-btn) {
					width: 100%;
				}
			}

	.about-section {
			padding: 1.5rem;
			margin: 2rem auto;
}

	.about-title {
			font-size: 1.5rem;
}

	.about-text,
	.about-footer {
			font-size: 1rem;
}

	.feature-text {
			font-size: 0.95rem;
			}
		</style>
	</body>
</html>
